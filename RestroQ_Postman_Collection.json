{
  "info": {
    "name": "RestroQ API - Phase 1",
    "description": "API collection for Authentication, Profile, and Restaurant Management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "restaurantId",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication & Profile",
      "item": [
        {
          "name": "Login (Super User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@quicktable.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/system",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login", "system"]
            }
          }
        },
        {
          "name": "Get My Profile (System)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/system/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "system", "me"]
            }
          }
        },
        {
          "name": "Login (Restaurant Owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.data.token);",
                  "    if (jsonData.data.user && jsonData.data.user.restaurant && jsonData.data.user.restaurant.id) {",
                  "        pm.collectionVariables.set(\"tenantId\", jsonData.data.user.restaurant.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@gourmet.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/user",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login", "user"]
            }
          }
        },
        {
          "name": "Get My Profile (User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "user", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Restaurant Management (Admins)",
      "item": [
        {
          "name": "Create Restaurant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.restaurant && jsonData.data.restaurant.id) {",
                  "    pm.collectionVariables.set(\"restaurantId\", jsonData.data.restaurant.id);",
                  "    pm.collectionVariables.set(\"tenantId\", jsonData.data.restaurant.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantName\": \"Gourmet Garden\",\n  \"slug\": \"gourmet-garden\",\n  \"phone\": \"01700000000\",\n  \"address\": \"123 Foodie St, Culinary City\",\n  \"ownerName\": \"John Gourmet\",\n  \"ownerEmail\": \"owner@gourmet.com\",\n  \"ownerPassword\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/restaurants",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants"]
            }
          }
        },
        {
          "name": "List All Restaurants",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants"]
            }
          }
        },
        {
          "name": "Get Restaurant Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}"]
            }
          }
        },
        {
          "name": "Update Restaurant Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subscriptionStatus\": \"active\",\n  \"isActive\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}"]
            }
          }
        },
        {
          "name": "Delete Restaurant",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Tenant Users",
          "item": [
            {
          "name": "Create Staff Member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Waiter One\",\n  \"email\": \"waiter1@gourmet.com\",\n  \"password\": \"password123\",\n  \"role\": \"WAITER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "List Own Staff (Me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "Get Specific Staff Member",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me/REPLACE_WITH_USER_ID",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me", "REPLACE_WITH_USER_ID"]
            }
          }
        },
        {
          "name": "Update Staff Member",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Waiter One Updated\",\n  \"role\": \"MANAGER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/me/REPLACE_WITH_USER_ID",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me", "REPLACE_WITH_USER_ID"]
            }
          }
        },
        {
          "name": "Delete Staff Member",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me/REPLACE_WITH_USER_ID",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me", "REPLACE_WITH_USER_ID"]
            }
          }
        }
      ]
    },
    {
      "name": "System Users",
      "item": [
        {
          "name": "List All Users (Admin Only)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/all",
              "host": ["{{baseUrl}}"],
              "path": ["users", "all"]
            }
          }
        },
        {
          "name": "List Tenant Users (Admin Only)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/tenant?tenantId={{restaurantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "tenant"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{restaurantId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Create System Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Admin\",\n  \"email\": \"newadmin@quicktable.com\",\n  \"password\": \"password123\",\n  \"role\": \"SYSTEM_STAFF\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/system",
              "host": ["{{baseUrl}}"],
              "path": ["users", "system"]
            }
          }
        },
        {
          "name": "List System Admins",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/system",
              "host": ["{{baseUrl}}"],
              "path": ["users", "system"]
            }
          }
        },
        {
          "name": "Get Specific System Admin",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/system/REPLACE_WITH_SYSTEM_USER_ID",
              "host": ["{{baseUrl}}"],
              "path": ["users", "system", "REPLACE_WITH_SYSTEM_USER_ID"]
            }
          }
        },
        {
          "name": "Update System Admin",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Admin Updated\",\n  \"role\": \"SUPER_USER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/system/REPLACE_WITH_SYSTEM_USER_ID",
              "host": ["{{baseUrl}}"],
              "path": ["users", "system", "REPLACE_WITH_SYSTEM_USER_ID"]
            }
          }
        },
        {
          "name": "Delete System Admin",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/system/REPLACE_WITH_SYSTEM_USER_ID",
              "host": ["{{baseUrl}}"],
              "path": ["users", "system", "REPLACE_WITH_SYSTEM_USER_ID"]
            }
          }
        }
      ]
    }
  ]
}
  ]
}
