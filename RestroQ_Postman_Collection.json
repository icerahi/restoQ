  "item": [
    {
      "name": "Authentication & Profile",
      "item": [
        {
          "name": "Login (Super User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@quicktable.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/system",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login",
                "system"
              ]
            }
          }
        },
        {
          "name": "Get My Profile (System)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/system/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "system",
                "me"
              ]
            }
          }
        },
        {
          "name": "Login (Restaurant Owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.data.token);",
                  "    if (jsonData.data.user && jsonData.data.user.restaurant && jsonData.data.user.restaurant.id) {",
                  "        pm.collectionVariables.set(\"tenantId\", jsonData.data.user.restaurant.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@gourmet.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login",
                "user"
              ]
            }
          }
        },
        {
          "name": "Get My Profile (User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/user/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "user",
                "me"
              ]
            }
          }
        }
      ]
    },
